# VoiceChatbox .env example
# Copy to .env and adjust as needed.

# -----------------------------
# OpenAI (required for Chat/TTS)
# -----------------------------
# API key for OpenAI
OPENAI_API_KEY=sk-...dein-api-key-hier...
# Chat model (LLM)
OPENAI_MODEL_CHAT=gpt-4.1-mini
# Speech-to-Text model (OpenAI)
OPENAI_MODEL_STT=gpt-4o-mini-transcribe
# Text-to-Speech model (OpenAI)
OPENAI_MODEL_TTS=gpt-4o-mini-tts
# TTS voice
OPENAI_TTS_VOICE=alloy

# -----------------------------
# Modes / Feature toggles
# -----------------------------
# Enable GPIO for PTT/LEDs
USE_GPIO=true
# Push-to-Talk mode for live recognition
USE_PTT=false
# Enable ChatGPT responses
USE_CHATGPT=true
# Use Vosk instead of OpenAI STT
USE_VOSK=false
# Use multi-language Vosk (de+en)
USE_MULTILANG=false
# Use smart multi-language mode
USE_SMART_MULTILANG=false

# -----------------------------
# Vosk (lokal, offline)
# -----------------------------
# Primary Vosk model path (German)
VOSK_MODEL_PATH=models/vosk-model-de-0.22
# Optional English model path
VOSK_MODEL_PATH_EN=models/vosk-model-en-us-0.22
# Alternate var used in multilang helper
VOSK_MODEL_PATH_DE=models/vosk-model-de-0.22
# Chunk length (seconds)
VOSK_CHUNK_DURATION=3.0
# Silence duration to finalize a sentence (seconds)
VOSK_PAUSE_DURATION=0.9
# OpenAI live STT pause duration (seconds)
LIVE_PAUSE_DURATION=0.9

# -----------------------------
# Whisper.cpp (lokal, offline)
# -----------------------------
# Enable whisper.cpp instead of OpenAI STT
USE_WHISPER_CPP=false
# Path to whisper.cpp binary
WHISPER_CPP_BIN=whisper.cpp/main
# Path to ggml model
WHISPER_CPP_MODEL=models/ggml-base.bin
# Language (e.g. de, en). Empty = auto
WHISPER_CPP_LANGUAGE=de
# Threads for whisper.cpp
WHISPER_CPP_THREADS=4
# Temperature for whisper.cpp
WHISPER_CPP_TEMPERATURE=0.0
# Extra CLI args for whisper.cpp
WHISPER_CPP_EXTRA_ARGS=

# -----------------------------
# Audio devices
# -----------------------------
# Input/output device patterns
AUDIO_INPUT_DEVICE=reSpeaker XVF3800 4-Mic Array
AUDIO_OUTPUT_DEVICE=Logitech USB Headset
# Retry if device not found (seconds)
INPUT_DEVICE_RETRY_SEC=5.0
INPUT_DEVICE_RETRY_INTERVAL=0.5
OUTPUT_DEVICE_RETRY_SEC=5.0
OUTPUT_DEVICE_RETRY_INTERVAL=0.5

# Mute output when idle (requires amixer)
MUTE_OUTPUT_WHEN_IDLE=false
# Volume percent when output active
OUTPUT_VOLUME_PERCENT=60
# Mixer control name
OUTPUT_VOLUME_CONTROL=Master

# -----------------------------
# VAD / Audio processing
# -----------------------------
# Enable preprocessing (high-pass + normalization)
ENABLE_AUDIO_PROCESSING=true
# Base RMS threshold
VAD_RMS_THRESHOLD=0.01
# Dynamic noise multiplier
VAD_NOISE_MULTIPLIER=3.0
# Noise floor smoothing (0..1)
VAD_NOISE_ALPHA=0.1
# Hangover factor for end-of-speech
VAD_HANGOVER_FACTOR=0.6
# Pre-roll seconds for speech start
VAD_PREROLL_SEC=0.2
# Use WebRTC VAD (robust against noise)
VAD_USE_WEBRTCVAD=true
# WebRTC VAD mode 0..3
VAD_WEBRTCVAD_MODE=2
# WebRTC VAD frame length (ms): 10/20/30
VAD_WEBRTCVAD_FRAME_MS=30

# -----------------------------
# Commands / wake phrases
# -----------------------------
WAKE_PHRASES=ok google,okay google,hey google,start
CONTEXT_PHRASES=ok google weiter,okay google weiter,hey google weiter,ok weiter,okay weiter,weiter
STOP_PHRASES=stopp,stop

# -----------------------------
# Chat filtering / confirmation
# -----------------------------
MIN_CHAT_WORDS=2
TRIVIAL_WORDS=
CHAT_FILTER_DEBUG=false
CHAT_IGNORE_AFTER_TTS_SEC=2.0
CONFIRM_BEFORE_CHAT=false
CONFIRM_PHRASES=ok,okay,ja,yes
REJECT_PHRASES=nein,no,falsch,abbruch
CONFIRM_TIMEOUT_SEC=6.0

# -----------------------------
# Chat system prompts
# -----------------------------
CHAT_SYSTEM_PROMPT_NEW=Du behandelst jede Eingabe als eigenständige, neue Frage. Kein Bezug zu früheren Fragen oder Antworten. Keine Kontextübernahme.
CHAT_SYSTEM_PROMPT_CONTEXT=Du bist ein hilfreicher, knapper Sprachassistent. Du darfst Kontext der laufenden Unterhaltung berücksichtigen.

# -----------------------------
# Echo / Announcements
# -----------------------------
# Speak recognized text before sending to ChatGPT
ECHO_INPUT_BEFORE_CHAT=true
# Use local TTS for echo
ECHO_INPUT_LOCAL_TTS=true
# Announce the exact ChatGPT request
ANNOUNCE_CHAT_REQUEST=true

# -----------------------------
# Status behavior
# -----------------------------
# Auto-pause after inactivity (seconds)
AUTO_PAUSE_AFTER_SEC=10
# Hold READY for N seconds after answer/reject
READY_HOLD_SEC=10.0

# -----------------------------
# History (TTS)
# -----------------------------
# JSON index for saved answers
HISTORY_PATH=data/tts_history/index.json
# Directory for OGG files
HISTORY_DIR=data/tts_history
# Max number of saved answers
HISTORY_MAX=50

# -----------------------------
# GPIO / OLED
# -----------------------------
# Optional pin factory (gpiozero)
GPIOZERO_PIN_FACTORY=
# GPIO pins
GPIO_PTT=17
GPIO_LED_RED=16
GPIO_LED_YELLOW=20
GPIO_LED_GREEN=21
# OLED I2C address
OLED_I2C_ADDR=0x3C

# -----------------------------
# Debugging
# -----------------------------
DEBUG_LOGS=false

# -----------------------------
# CLI flags (examples)
# -----------------------------
# Live recognition:
#   python -m src.main --live-recognition
# Use Vosk:
#   python -m src.main --live-recognition --vosk
# Use smart-multilang:
#   python -m src.main --live-recognition --vosk --smart-multilang
# Use multilang:
#   python -m src.main --live-recognition --vosk --multilang
# Push-to-talk:
#   python -m src.main --live-recognition --ptt
# ChatGPT responses:
#   python -m src.main --live-recognition --chatgpt
# Force mode (PTT main loop):
#   python -m src.main --mode echo
#   python -m src.main --mode chatbox
