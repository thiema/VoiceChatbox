cd /home/marian/Projects/VoiceChatbox && python3 - <<'PY'
from pathlib import Path
content = """# VoiceChatbox configuration (.env)
# Copy to .env and adjust as needed.

# --- OpenAI / Modelle ---
# API Key (Pflicht)
OPENAI_API_KEY=PASTE_YOUR_KEY_HERE
# Chat‑Modell
OPENAI_MODEL_CHAT=gpt-4.1-mini
# STT‑Modell (für Whisper)
OPENAI_MODEL_STT=gpt-4o-mini-transcribe
# TTS‑Modell
OPENAI_MODEL_TTS=gpt-4o-mini-tts
# Stimme für TTS
OPENAI_TTS_VOICE=alloy

# --- Features / Modi (alternativ per CLI flags) ---
# Aktiviert ChatGPT‑Antworten
USE_CHATGPT=true
# Vosk lokales Modell
USE_VOSK=true
# Mehrsprachig (Vosk)
USE_MULTILANG=false
# Smart Multilang (DE+EN Kontext)
USE_SMART_MULTILANG=false
# Push‑to‑Talk via GPIO
USE_PTT=false

# --- Audio‑Geräte (string pattern, keine Reihenfolge‑Annahme) ---
# Beispiele: Teilname, oder "token1|token2", oder "card=...;device=..."
AUDIO_INPUT_DEVICE=reSpeaker XVF3800 4-Mic Array
AUDIO_OUTPUT_DEVICE=Logitech USB Headset

# --- Vosk (lokal/offline) ---
VOSK_MODEL_PATH=models/vosk-model-de-0.21
VOSK_MODEL_PATH_DE=models/vosk-model-de-0.21
VOSK_MODEL_PATH_EN=models/vosk-model-en-us-0.22

# --- Live‑Erkennung ---
# Pause nach Sprachende (Sek.)
LIVE_PAUSE_DURATION=0.9
# Mindestwortzahl für ChatGPT
MIN_CHAT_WORDS=2
# Triviale Wörter, die nicht gesendet werden
TRIVIAL_WORDS=die,aber,oder,etc
# Debug für Chat‑Filter
CHAT_FILTER_DEBUG=false
# Sperrzeit nach TTS, um Echo zu vermeiden (Sek.)
CHAT_IGNORE_AFTER_TTS_SEC=2.0
# Automatisches Pausieren nach Inaktivität (Sek.)
AUTO_PAUSE_AFTER_SEC=10
# Debug‑Logs aktivieren
DEBUG_LOGS=false

# --- Wake/Stop Commands ---
WAKE_PHRASES=ok google,okay google,hey google,start
CONTEXT_PHRASES=ok google weiter,okay google weiter,hey google weiter
STOP_PHRASES=stopp,stop

# --- Chat System Prompts ---
# "BEREIT" (neuer Kontext)
CHAT_SYSTEM_PROMPT_NEW=Du behandelst jede Eingabe als eigenständige, neue Frage. Kein Bezug zu früheren Fragen oder Antworten. Keine Kontextübernahme.
# "BEREIT MIT Kontext"
CHAT_SYSTEM_PROMPT_CONTEXT=Du bist ein hilfreicher, knapper Sprachassistent. Du darfst Kontext der laufenden Unterhaltung berücksichtigen.

# --- Echo / Wiedergabe ---
# Erkannten Text vor ChatGPT ausgeben (Audio)
ECHO_INPUT_BEFORE_CHAT=true
# Echo lokal sprechen (pyttsx3); false = OpenAI‑TTS
ECHO_INPUT_LOCAL_TTS=true
# Exakte OpenAI‑Frage in Konsole + Audio ausgeben
ANNOUNCE_CHAT_REQUEST=true

# --- Audio‑Vorverarbeitung ---
# High‑Pass + Normalisierung
ENABLE_AUDIO_PROCESSING=true

# --- VAD (Voice Activity Detection) ---
# Basis‑RMS‑Schwelle
VAD_RMS_THRESHOLD=0.01
# Dynamische Schwelle = noise_floor * multiplier
VAD_NOISE_MULTIPLIER=3.0
# EMA‑Faktor für Noise‑Floor
VAD_NOISE_ALPHA=0.1

# --- GPIO / LEDs / PTT ---
USE_GPIO=true
GPIOZERO_PIN_FACTORY=
GPIO_PTT=17
GPIO_LED_RED=16
GPIO_LED_YELLOW=20
GPIO_LED_GREEN=21

# --- OLED Display ---
OLED_DRIVER=sh1106
OLED_I2C_BUS=1
OLED_I2C_ADDR=0x3C
OLED_WIDTH=128
OLED_HEIGHT=32
OLED_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
OLED_FONT_SIZE=12
OLED_MARGIN_LEFT=4
OLED_MARGIN_TOP=3
OLED_MARGIN_RIGHT=4
OLED_MARGIN_BOTTOM=4
OLED_TEXT_DX=1
OLED_TEXT_DY=7
"""
Path('.env.example').write_text(content)
print('written')
PY