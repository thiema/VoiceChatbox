[Unit]
Description=Raspberry Pi KI-Chatbox
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/marian/Projects/VoiceChatbox
EnvironmentFile=/home/marian/Projects/VoiceChatbox/.env
ExecStart=/home/marian/Projects/VoiceChatbox/.venv/bin/python -m src.main --live-recognition --vosk --chatgpt
Restart=on-failure
RestartSec=2

# Audio permissions
User=marian
Group=marian

[Install]
WantedBy=multi-user.target
